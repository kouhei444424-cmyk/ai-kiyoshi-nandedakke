# 公開後に、確定した pages.dev URL または独自ドメインを指定します。
SITE_URL=http://localhost:4321

# 未設定または空欄なら、記事末尾にリンクは表示されません。
AFFILIATE_URL=

# アフィリエイト審査中など、通常リンクを表示するときに指定します。
# AFFILIATE_URLが設定されている場合は、そちらを優先します。
ADULT_LINK_URL=https://www.dmm.co.jp/top/

# Cloudflare Turnstile（コメント投稿のBot対策）のサイトキーです。公開値なのでビルド変数として扱えます。
# 本番はCloudflare Dashboard > Turnstileで発行し、Cloudflare Pagesの
# Environment variables（Production / Preview 両方）に PUBLIC_TURNSTILE_SITE_KEY として設定してください。
# ローカル確認では、Cloudflare公式のテスト用キー（常に成功する組み合わせ）を使えます。
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# 以下はCloudflare Pagesのsecret（wrangler pages secret put）として設定するため、
# .env / .env.example には値を書きません（ローカルでFunctionsを試す場合のみ .dev.vars に設定します）。
# TURNSTILE_SECRET_KEY : Turnstileのシークレットキー（ローカルのテスト用: 1x0000000000000000000000000000000AA）
# COMMENT_HASH_SALT    : 連投判定のハッシュ化に使う十分に長いランダム値
# COMMENT_ADMIN_TOKEN  : コメント管理画面（/admin/comments/）用の管理者トークン
